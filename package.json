{
  "name": "sangoku-site",
  "version": "1.2.37",
  "description": "Room Correction Helper - Audio calibration and optimization tool",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "test:smoke:knockout": "node test/knockout-trusted-types.smoke.test.js",
    "test:smoke:browser": "node test/app-startup.browser.smoke.test.js",
    "test:smoke": "npm run build && npm run test:smoke:knockout && npm run test:smoke:browser",
    "versionCommit": "script/release-vite.sh",
    "publish": "script/publish-vite.sh",
    "clean": "rm -rf dist && rm -rf node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jzahraoui/sangoku-site.git"
  },
  "keywords": [
    "audio",
    "room-correction",
    "equalization",
    "audyssey",
    "subwoofer"
  ],
  "author": "Sangoku",
  "license": "GNU Affero General Public License",
  "bugs": {
    "url": "https://github.com/jzahraoui/sangoku-site/issues"
  },
  "homepage": "https://github.com/jzahraoui/sangoku-site#application",
  "dependencies": {
    "@stanko/dual-range-input": "^1.0.1",
    "decimal.js": "^10.6.0",
    "file-saver": "^2.0.5",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "knockout": "3.5.3",
    "mathjs": "^15.1.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    ">1%",
    "not dead",
    "not op_mini all"
  ]
}
