    "test:cleanup": "node --test test/auto-eq/filter-cleanup.test.js",
    "test:optimizer-config": "node --test test/auto-eq/optimizer-config.test.js",
    "example:basic": "node examples/basic-usage.js",
    "test:examples": "npm run example:basic",
    "test:quality": "npm run test:all && npm run test:overshoots",
    "test:initial-metrics": "node --test test/auto-eq/initial-metrics.test.js",
    "test:residuals": "node --test test/auto-eq/residuals.test.js",
