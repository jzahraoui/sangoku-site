{
  "name": "sangoku-site",
  "version": "1.2.46",
  "description": "Room Correction Helper - Audio calibration and optimization tool",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:audio-selection": "vitest run test/unit/audio-selection.test.js",
    "test:frequency-response-processor": "node --test test/node/frequency-response-processor.test.js",
    "test:genetic-algorithm": "vitest run test/unit/genetic-algorithm.test.js",
    "test:multi-sub-optimizer-general": "vitest run test/unit/multi-sub-optimizer-general.test.js",
    "test:multi-sub-optimizer-all": "node test/integration/multi-sub-optimizer.all.test.js",
    "test:rew-api": "vitest run test/unit/rew-api.test.js",
    "test:scorer": "vitest run test/unit/scorer.test.js",
    "test:watch": "vitest",
    "test:smoke:knockout": "node test/smoke/knockout-trusted-types.smoke.test.js",
    "test:smoke:browser": "node test/smoke/app-startup.browser.smoke.test.js",
    "test:smoke:slider": "node test/smoke/frequency-range-slider.browser.smoke.test.js",
