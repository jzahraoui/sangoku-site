    "test:hf-coverage": "node --test test/auto-eq/hf-coverage.test.js",
    "test:beat-rew": "node --test test/auto-eq/beat-rew-enhancements.test.js",
    "test:final-optimization": "node --test test/auto-eq/final-optimization-stages.test.js",
    "test:placement-pipeline": "node --test test/auto-eq/placement-pipeline.test.js",
    "test:placement-challenger": "node --test test/auto-eq/candidate-placement-challenger.test.js",
    "test:public-api": "node --test test/auto-eq/public-api-smoke.test.js",
    "test:entrypoints": "node --test test/auto-eq/public-entrypoints.test.js",
    "test:parameter-transform": "node --test test/auto-eq/parameter-transform.test.js",
    "test:grid-weighting": "node --test test/auto-eq/grid-weighting.test.js",
    "test:filter-parameter-bounds": "node --test test/auto-eq/filter-parameter-bounds.test.js",
    "test:filter-mse-kernel": "node --test test/auto-eq/filter-mse-kernel.test.js",
    "test:frequency-grid": "node --test test/auto-eq/frequency-grid.test.js",
    "test:optimization-state": "node --test test/auto-eq/optimization-state.test.js",
    "test:optimizer-decoding": "node --test test/auto-eq/optimizer-decoding.test.js",
    "test:biquad-coefficients": "node --test test/auto-eq/biquad-coefficients.test.js",
    "test:biquad-response": "node --test test/auto-eq/biquad-response.test.js",
    "test:peaking-magnitude": "node --test test/auto-eq/peaking-magnitude.test.js",
    "test:peaking-profiles": "node --test test/auto-eq/peaking-profiles.test.js",
    "test:mse-grid": "node --test test/auto-eq/mse-grid.test.js",
    "test:fast-mse": "node --test test/auto-eq/fast-mse.test.js",
