  "homepage": "https://github.com/jzahraoui/sangoku-site#application",
  "dependencies": {
    "decimal.js": "^10.6.0",
    "file-saver": "^2.0.5",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "knockout": "3.5.3",
    "mathjs": "^15.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
