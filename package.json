    "test:rew-api-filters": "node test/auto-eq/rew/rew-api-filters.test.js",
    "test:rew-api-live": "node test/auto-eq/rew/rew-api.test.js",
    "test:rew-files": "node test/auto-eq/rew/rew-files.test.js",
    "test:rew-filters": "node test/auto-eq/rew/rew-filters.test.js",
    "test:rew-parity-strict": "node --test test/auto-eq/rew/rew-parity-strict.test.js",
    "test:rew-strict-identity": "node --test test/auto-eq/rew/rew-strict-identity.test.js",
    "test:filters": "node test/auto-eq/compare-filters.test.js",
    "test:bench": "node test/auto-eq/benchmark.test.js",
    "test:overshoots": "node test/auto-eq/analyze-overshoots.test.js",
    "test:analyze-example1-detail": "node test/auto-eq/analyze-example1-detail.test.js",
    "test:analyze-key-frequencies": "node test/auto-eq/analyze-key-frequencies.test.js",
    "test:analyze-rew-overshoots": "node test/auto-eq/analyze-rew-overshoots.test.js",
    "test:compare-example1-40-3000": "node test/auto-eq/compare-example1-40-3000.test.js",
    "test:compare-tracking": "node test/auto-eq/compare-tracking.test.js",
    "test:show-filters-ex1": "node test/auto-eq/show-filters-ex1.test.js",
    "test:characterization": "node --test test/auto-eq/autoeq-characterization.test.js",
    "test:utils": "node --test test/auto-eq/filter-utils.test.js",
    "test:overshoot": "node --test test/auto-eq/target-overshoot.test.js",
    "test:regularizer": "node --test test/auto-eq/perceptual-regularizer.test.js",
